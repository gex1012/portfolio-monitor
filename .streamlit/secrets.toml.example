# Copy this content into Streamlit Community Cloud > App settings > Secrets.
# Do not commit a real .streamlit/secrets.toml file.

[fmp]
api_key = "YOUR_FMP_API_KEY"

[account]
base_hkd = 4000000

[auth]
viewer_password = "viewer-password"
editor_password = "editor-password"
admin_password = "admin-password"

[apps_script]
url = "YOUR_GOOGLE_APPS_SCRIPT_WEB_APP_URL"
token = "MAKE_A_LONG_RANDOM_TOKEN"

[google_sheets]
sheet_id = "1a9ahW9brvGS6B2QMDgUwRQmLRXiHDKecX4G-oZ8acFQ"
trades_worksheet = "Trades"
audit_worksheet = "Audit Log"

# Optional fallback only. Not needed when [apps_script] is configured.
# Create a Google Cloud service account, enable Google Sheets API,
# share the Google Sheet with client_email below as Editor,
# then paste the service account JSON fields here.
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "your-private-key-id"
private_key = """-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_LINES_HERE
-----END PRIVATE KEY-----
"""
client_email = "your-service-account@your-project-id.iam.gserviceaccount.com"
client_id = "your-client-id"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project-id.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
